DATABASE_URL=postgres://drp:drp@localhost:5433/drp
PORT=3000

# Demo seeding on boot: "reset" (default; wipes + reseeds each boot, for local dev),
# "if-empty" (seed only a fresh DB, used on the live backend), or "off".
# SEED_ON_BOOT=reset

# Path to a CA bundle for verifying TLS to the database (set in the Docker image for RDS).
# Leave unset locally - plaintext is used for a localhost connection.
# DATABASE_CA_PATH=/app/rds-ca.pem
