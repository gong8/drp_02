{
  "name": "bethere-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "concurrently -k -n api,mobile -c blue,magenta \"pnpm --filter @bethere/api dev\" \"pnpm --filter @bethere/mobile ios\"",
    "dev:mobile": "pnpm --filter @bethere/mobile start",
    "dev:api": "pnpm --filter @bethere/api dev",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "biome check",
    "format": "biome check --write",
    "quality": "node scripts/quality-check.mjs",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm quality",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "concurrently": "^9.1.0"
  }
}
